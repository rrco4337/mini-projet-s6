# Réécriture d'URL pour routeur
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirections legacy (.php) vers les routes propres
    RewriteRule ^admin/index\.php$ /admin [R=301,L]
    RewriteRule ^admin/articles\.php$ /admin/articles [R=301,L]
    RewriteRule ^admin/categories\.php$ /admin/categories [R=301,L]
    RewriteRule ^login\.php$ /login [R=301,L]
    RewriteRule ^logout\.php$ /logout [R=301,L]

    # Edition article legacy: /admin/article-edit.php?id=123 -> /admin/article/123/edit
    RewriteCond %{REQUEST_URI} ^/admin/article-edit\.php$ [NC]
    RewriteCond %{QUERY_STRING} (^|&)id=([0-9]+)(&|$) [NC]
    RewriteRule ^admin/article-edit\.php$ /admin/article/%2/edit? [R=301,L]

    # Creation article legacy: /admin/article-edit.php -> /admin/article/new
    RewriteRule ^admin/article-edit\.php$ /admin/article/new [R=301,L]
    
    # Permettre les fichiers/dossiers existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rediriger tout vers index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Sécurité
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Protéger fichiers sensibles
<FilesMatch "config\.php">
    Order allow,deny
    Deny from all
</FilesMatch>

# Désactiver listing répertoires
Options -Indexes

# Configuration PHP
<IfModule mod_php.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 25M
    php_value max_execution_time 300
</IfModule>
